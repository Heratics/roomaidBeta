# ==============================
# RoomAid Render Environment
# ==============================

# Server
PORT=3000
SESSION_SECRET=replace-with-long-random-session-secret
JWT_SECRET=replace-with-long-random-jwt-secret

# MySQL
DB_SERVER=your-mysql-hostname
DB_PORT=3306
DB_USER=your-mysql-username
DB_PASSWORD=your-mysql-password
DB_NAME=roomaid

# MySQL SSL flags
# For most managed DBs, keep DB_ENCRYPT=true.
# Set DB_TRUST_CERT=true only if your provider requires bypassing CA validation.
DB_ENCRYPT=true
DB_TRUST_CERT=false

# FCM (choose one method)
# Preferred: full Firebase service account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# Optional fallback (legacy)
FCM_SERVER_KEY=

# Optional override (usually inferred from FIREBASE_SERVICE_ACCOUNT.project_id)
FCM_PROJECT_ID=your-project-id

# Legacy web-push vars (kept for compatibility in config.js)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
